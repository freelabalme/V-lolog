<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<meta name="mobile-web-app-capable" content="yes">
<title>🍌 Ravito Timer</title>
<style>
* { margin:0; padding:0; box-sizing:border-box; }
:root {
  --bg: #04060a; --card: #0a0f18; --border: #1a2535;
  --orange: #ff6b35; --green: #39ff8f; --yellow: #ffd060;
  --text: #e8f0f8; --muted: #5a7080;
}
html, body { height:100%; background:var(--bg); color:var(--text); font-family:'Segoe UI',Arial,sans-serif; }
body::before { content:''; position:fixed; inset:0; background:radial-gradient(ellipse 80% 60% at 50% 30%, rgba(255,208,96,0.06) 0%, transparent 70%); pointer-events:none; z-index:0; }
.app { position:relative; z-index:1; min-height:100vh; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:20px; gap:16px; }
.titre { text-align:center; }
.titre h1 { font-size:1.8rem; font-weight:900; letter-spacing:3px; color:var(--yellow); text-transform:uppercase; }
.titre p { font-size:0.75rem; color:var(--muted); margin-top:4px; letter-spacing:1px; }
.timer-card { background:var(--card); border:2px solid var(--border); border-radius:20px; padding:28px 36px; text-align:center; width:100%; max-width:360px; position:relative; overflow:hidden; }
.timer-card::before { content:''; position:absolute; top:0; left:0; right:0; height:3px; background:linear-gradient(90deg,var(--yellow),var(--orange)); }
.timer-label { font-size:0.62rem; color:var(--muted); text-transform:uppercase; letter-spacing:2px; margin-bottom:8px; }
.timer-display { font-size:3.8rem; font-weight:900; letter-spacing:4px; color:var(--yellow); text-shadow:0 0 30px rgba(255,208,96,0.4); font-variant-numeric:tabular-nums; line-height:1; }
.timer-display.urgent { color:var(--orange); text-shadow:0 0 30px rgba(255,107,53,0.5); animation:pulse 1s infinite; }
.timer-sub { font-size:0.7rem; color:var(--muted); margin-top:8px; }
@keyframes pulse { 0%,100%{opacity:1;} 50%{opacity:0.5;} }
.next-card { background:var(--card); border:1px solid var(--border); border-radius:14px; padding:14px 20px; text-align:center; width:100%; max-width:360px; }
.next-label { font-size:0.6rem; color:var(--muted); text-transform:uppercase; letter-spacing:1.5px; margin-bottom:4px; }
.next-time { font-size:2rem; font-weight:900; color:var(--orange); letter-spacing:2px; }
.next-sub { font-size:0.7rem; color:var(--muted); margin-top:3px; }
.count-card { display:flex; gap:12px; width:100%; max-width:360px; }
.count-item { flex:1; background:var(--card); border:1px solid var(--border); border-radius:12px; padding:12px; text-align:center; }
.count-label { font-size:0.58rem; color:var(--muted); text-transform:uppercase; letter-spacing:1px; margin-bottom:3px; }
.count-val { font-size:1.6rem; font-weight:900; }
.count-item:first-child .count-val { color:var(--green); }
.count-item:last-child .count-val { color:var(--yellow); }
.btn-row { display:flex; gap:10px; width:100%; max-width:360px; }
.btn { flex:1; padding:15px; border:none; border-radius:14px; font-size:0.88rem; font-weight:700; letter-spacing:1px; text-transform:uppercase; cursor:pointer; transition:all 0.2s; }
.btn-start { background:linear-gradient(135deg,var(--yellow),var(--orange)); color:#04060a; box-shadow:0 4px 20px rgba(255,208,96,0.3); }
.btn-start:active { transform:scale(0.97); }
.btn-stop { background:rgba(255,64,96,0.15); color:#ff4060; border:1px solid rgba(255,64,96,0.3); }
.btn-test { background:rgba(57,255,143,0.12); color:var(--green); border:1px solid rgba(57,255,143,0.3); font-size:0.78rem; flex:0.6; }
.motivation-card { background:var(--card); border:1px solid rgba(255,208,96,0.3); border-radius:12px; padding:14px 18px; width:100%; max-width:360px; text-align:center; }
.motivation-label { font-size:0.58rem; color:var(--muted); text-transform:uppercase; letter-spacing:1.5px; margin-bottom:6px; }
.motivation-text { font-size:0.9rem; color:var(--yellow); font-weight:600; line-height:1.4; }
.log-card { width:100%; max-width:360px; background:var(--card); border:1px solid var(--border); border-radius:12px; overflow:hidden; }
.log-header { padding:8px 14px; background:rgba(0,0,0,0.3); font-size:0.6rem; color:var(--muted); text-transform:uppercase; letter-spacing:2px; border-bottom:1px solid var(--border); }
.log-list { max-height:100px; overflow-y:auto; }
.log-item { padding:7px 14px; border-bottom:1px solid rgba(30,42,53,0.5); font-size:0.72rem; display:flex; gap:10px; }
.log-item:last-child { border-bottom:none; }
.log-time { color:var(--muted); flex-shrink:0; }
.log-msg { color:var(--green); }
.toast { position:fixed; top:20px; left:50%; transform:translateX(-50%) translateY(-80px); background:var(--card); border:1px solid var(--yellow); border-radius:12px; padding:11px 20px; font-size:0.82rem; font-weight:600; z-index:1000; transition:transform 0.4s cubic-bezier(0.34,1.56,0.64,1); white-space:nowrap; color:var(--yellow); }
.toast.show { transform:translateX(-50%) translateY(0); }
.toast.green { border-color:var(--green); color:var(--green); }
.dbtn { flex:1; padding:8px; border:1px solid var(--border); background:var(--card); color:var(--text); border-radius:8px; font-weight:700; cursor:pointer; font-size:0.82rem; transition:all 0.2s; }
.dbtn.active { border-color:var(--yellow); background:rgba(255,208,96,0.12); color:var(--yellow); }
</style>
</head>
<body>
<div class="app">

  <div class="titre">
    <h1>🍌 Ravito Timer</h1>
    <p>⚠️ MODE TEST — Ravito toutes les 2 minutes ⚠️</p>
  </div>

  <div class="timer-card">
    <div class="timer-label">⏱ Depuis le dernier ravito</div>
    <div class="timer-display" id="timer-display">00:00</div>
    <div class="timer-sub" id="timer-sub">Appuie sur DÉMARRER au départ</div>
  </div>

  <div class="next-card">
    <div class="next-label">🍌 Prochain ravito dans</div>
    <div class="next-time" id="next-time">—</div>
    <div class="next-sub" id="next-sub">toutes les heures</div>
  </div>

  <div class="count-card">
    <div class="count-item">
      <div class="count-label">✅ Ravitos</div>
      <div class="count-val" id="count-ravito">0</div>
    </div>
    <div class="count-item">
      <div class="count-label">⏱ Course</div>
      <div class="count-val" id="count-course">0h00</div>
    </div>
  </div>

  <div class="motivation-card">
    <div class="motivation-label">💬 Message en cours</div>
    <div class="motivation-text" id="motivation-text">En attente du départ...</div>
  </div>

  <div style="width:100%;max-width:360px;">
    <div style="font-size:0.62rem;color:var(--muted);text-transform:uppercase;letter-spacing:1.5px;margin-bottom:8px;text-align:center;">⏱ Je lance combien de minutes avant le départ ?</div>
    <div style="display:flex;gap:8px;margin-bottom:10px;justify-content:center;">
      <button onclick="setDecalage(0)"  id="d0"  class="dbtn">0 min</button>
      <button onclick="setDecalage(5)"  id="d5"  class="dbtn">5 min</button>
      <button onclick="setDecalage(10)" id="d10" class="dbtn active">10 min</button>
      <button onclick="setDecalage(15)" id="d15" class="dbtn">15 min</button>
    </div>
  </div>
  <div class="btn-row">
    <button class="btn btn-start" id="btn-main" onclick="toggleTimer()">▶ DÉMARRER</button>
    <button class="btn btn-test" onclick="testTelegram()">✈️ TEST</button>
  </div>

  <div class="log-card">
    <div class="log-header">✈️ Messages Telegram</div>
    <div class="log-list" id="log-list">
      <div class="log-item"><span class="log-time">--:--</span><span class="log-msg">En attente...</span></div>
    </div>
  </div>

</div>
<div class="toast" id="toast"></div>

<script>
const TG_TOKEN   = '8365892145:AAEthGgrUicLfX_rj58s6H3LhNExbd1jmlU';
const TG_CHAT_ID = '8659184335';
const INTERVALLE = 2 * 60 * 1000; // 2min POUR TEST (remettre 60*60*1000 pour la course !)

// Messages de motivation par heure
// Index = numéro du ravito (1=après 1h, 2=après 2h, etc.)
const MESSAGES = {
  0:  "🚵 MB Race démarrée !\nAllez Fabien, c'est parti ! 💪\n🍌 Premier ravito dans 1 heure !",
  1:  "🍌 C'est le moment de manger !\n⏱ 1h de course · Ravito n°1\nT'es frais, le rythme est bon — mange et profites-en !",
  2:  "🍌 C'est le moment de manger !\n⏱ 2h de course · Ravito n°2\nPraz sur Arly bientôt — fais le plein avant la montée !",
  3:  "🍌 C'est le moment de manger !\n⏱ 3h de course · Ravito n°3\nLe Col de Very approche — les jambes ont besoin de carburant !",
  4:  "🍌 C'est le moment de manger !\n⏱ 4h de course · Ravito n°4\nLe plus dur est devant toi — mange maintenant, pas après ! 🔥",
  5:  "🍌 C'est le moment de manger !\n⏱ 5h de course · Ravito n°5\nRetour à Megève dans le viseur — t'es une machine ! 💪",
  6:  "🍌 C'est le moment de manger !\n⏱ 6h de course · Ravito n°6\nMi-course passée ! Le plus beau reste à faire — mange champion !",
  7:  "🍌 C'est le moment de manger !\n⏱ 7h de course · Ravito n°7\nPlateau de la Croix bientôt — le sucre c'est ton ami !",
  8:  "🍌 C'est le moment de manger !\n⏱ 8h de course · Ravito n°8\nCombloux dans le viseur — accroche-toi, t'es plus fort que la fatigue !",
  9:  "🍌 C'est le moment de manger !\n⏱ 9h de course · Ravito n°9\nLes jambes peuvent encore souffrir — le ventre lui ne doit pas ! 💥",
  10: "🍌 C'est le moment de manger !\n⏱ 10h de course · Ravito n°10\nSous Col du Jaillet passé ou presque — la fin approche, lâche rien !",
  11: "🍌 C'est le moment de manger !\n⏱ 11h de course · Ravito n°11\nBall Trap dans le viseur — t'as survécu à pire ! Mange et fonce !",
  12: "🍌 C'est le moment de manger !\n⏱ 12h de course · Ravito n°12\nMegève t'attend ! Plus que quelques cols — tu vas le finir ce monstre ! 🏔️",
  13: "🍌 C'est le moment de manger !\n⏱ 13h de course · Ravito n°13\nLes derniers kilomètres — mange une dernière fois et tout donner !",
  14: "🏆 FINISHER !\n⏱ 14h de course\nFabien RONDI — MB Race Ultra 2026 — FINISHER ! 🎉🏆🚵",
};

let running = false;
let startTime = null;
let lastRavito = null;
let ravitoCpt = 0;
let timerInterval = null;
let nextRavitoTimeout = null;
let telegramMsgId = null; // ID du message à éditer
let decalageMin = 10; // Minutes avant le départ

function setDecalage(min) {
  decalageMin = min;
  document.querySelectorAll('.dbtn').forEach(b => b.classList.remove('active'));
  document.getElementById('d' + min).classList.add('active');
}

// ── TELEGRAM : envoyer ou éditer ──
async function envoyerOuEditer(texte) {
  try {
    let url, body;
    if(telegramMsgId) {
      // Éditer le message existant
      url = `https://api.telegram.org/bot${TG_TOKEN}/editMessageText`;
      body = { chat_id: TG_CHAT_ID, message_id: telegramMsgId, text: texte };
    } else {
      // Créer le premier message
      url = `https://api.telegram.org/bot${TG_TOKEN}/sendMessage`;
      body = { chat_id: TG_CHAT_ID, text: texte };
    }
    const r = await fetch(url, {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify(body)
    });
    const d = await r.json();
    if(d.ok) {
      if(!telegramMsgId) telegramMsgId = d.result.message_id;
      addLog(texte.split('\n')[0]);
      document.getElementById('motivation-text').textContent = texte.split('\n')[0];
      showToast('✈️ Message envoyé !', 'green');
    } else {
      // Si édition échoue (message trop vieux), envoyer un nouveau
      if(telegramMsgId) {
        telegramMsgId = null;
        await envoyerOuEditer(texte);
      }
    }
  } catch(e) {
    showToast('❌ Erreur réseau', '');
  }
}

function testTelegram() {
  envoyerOuEditer("🍌 TEST — C'est le moment de manger !\n⏱ Ravito Timer MB Race 2026 ✅");
}

// ── TIMER ──
function toggleTimer() {
  if(!running) startTimer(); else stopTimer();
}

function startTimer() {
  running       = true;
  startTime     = Date.now();
  lastRavito    = Date.now();
  ravitoCpt     = 0;
  telegramMsgId = null;

  document.getElementById('btn-main').textContent = '⏹ STOP';
  document.getElementById('btn-main').className = 'btn btn-stop';

  // Message de départ
  envoyerOuEditer(MESSAGES[0]);

  // Lancer l'affichage toutes les secondes
  timerInterval = setInterval(updateDisplay, 1000);

  // Premier ravito : 1h après le DÉPART RÉEL
  // Si on lance 10min avant → premier ravito dans 50min
  const premierRavitoMs = Math.max(1000, INTERVALLE - (decalageMin * 60 * 1000));
  console.log('Premier ravito dans', Math.round(premierRavitoMs/60000), 'min');

  nextRavitoTimeout = setTimeout(function() {
    declencherRavito();
  }, premierRavitoMs);

  showToast('🚵 Course démarrée !', 'green');
}

function declencherRavito() {
  if(!running) return;
  ravitoCpt++;
  lastRavito = Date.now();
  document.getElementById('count-ravito').textContent = ravitoCpt;
  const msg = MESSAGES[ravitoCpt] || MESSAGES[14];
  envoyerOuEditer(msg);
  // Programmer le suivant dans exactement 1h
  nextRavitoTimeout = setTimeout(function() {
    declencherRavito();
  }, INTERVALLE);
}

function stopTimer() {
  running = false;
  clearInterval(timerInterval);
  clearTimeout(nextRavitoTimeout);
  document.getElementById('btn-main').textContent = '▶ DÉMARRER';
  document.getElementById('btn-main').className = 'btn btn-start';
  document.getElementById('timer-sub').textContent = 'Timer arrêté';
  document.getElementById('next-time').textContent = '—';
  showToast('⏹ Timer arrêté', '');
}

// programmerProchainRavito remplacé par declencherRavito

function updateDisplay() {
  if(!running) return;
  const now = Date.now();

  // Timer depuis dernier ravito
  const depuisSec = Math.floor((now - lastRavito) / 1000);
  const m = Math.floor(depuisSec / 60);
  const s = depuisSec % 60;
  const el = document.getElementById('timer-display');
  el.textContent = `${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
  el.className = m >= 50 ? 'timer-display urgent' : 'timer-display';
  document.getElementById('timer-sub').textContent = m >= 50
    ? '⚠️ Mange maintenant !'
    : 'Prochain ravito automatique dans...';

  // Temps avant prochain
  const resteSec = Math.max(0, Math.floor((INTERVALLE - (now - lastRavito)) / 1000));
  const rm = Math.floor(resteSec / 60);
  const rs = resteSec % 60;
  document.getElementById('next-time').textContent = `${String(rm).padStart(2,'0')}:${String(rs).padStart(2,'0')}`;
  document.getElementById('next-sub').textContent = rm < 5 ? '⚠️ Prépare ton ravito !' : 'toutes les heures';

  // Temps course total
  const courseSec = Math.floor((now - startTime) / 1000);
  const hC = Math.floor(courseSec / 3600);
  const mC = Math.floor((courseSec % 3600) / 60);
  document.getElementById('count-course').textContent = `${hC}h${String(mC).padStart(2,'0')}`;
}

function addLog(msg) {
  const now = new Date().toLocaleTimeString('fr-FR', {hour:'2-digit', minute:'2-digit'});
  const log = document.getElementById('log-list');
  const item = document.createElement('div');
  item.className = 'log-item';
  item.innerHTML = `<span class="log-time">${now}</span><span class="log-msg">${msg.substring(0,45)}</span>`;
  log.prepend(item);
  while(log.children.length > 10) log.removeChild(log.lastChild);
}

function showToast(msg, type='') {
  const t = document.getElementById('toast');
  t.textContent = msg; t.className = 'toast show ' + type;
  setTimeout(() => t.classList.remove('show'), 3000);
}
</script>
</body>
</html>
